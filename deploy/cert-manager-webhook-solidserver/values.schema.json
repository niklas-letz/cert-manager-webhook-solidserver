{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": false,
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "certManager": {
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "default": "cert-manager",
          "title": "namespace",
          "type": "string"
        },
        "serviceAccountName": {
          "default": "cert-manager",
          "title": "serviceAccountName",
          "type": "string"
        }
      },
      "required": [
        "namespace",
        "serviceAccountName"
      ],
      "title": "certManager",
      "type": "object"
    },
    "fullnameOverride": {
      "default": "",
      "title": "fullnameOverride",
      "type": "string"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "groupName": {
      "default": "acme.solidserver.niklasletz.dev",
      "description": "The groupName avoids naming conflicts on the Kubernetes API, it should be set by the\nauthor of the webhook a unique domain that the author owns. For\nexample: some-provider-webhook.mycompany.tld , or\nsome-provider-webhook.mypersonalsite.tld if your webhook is a personal open-source\nproject.\nOnce set to a unique domain name by the webhook author, it does not need to be further\nadjusted by the users of a webhook chart!\nThe name will need to be referenced in each Issuer's `webhook` stanza to\ninform cert-manager of where to send ChallengePayload resources in order to\nsolve the DNS01 challenge.",
      "title": "groupName",
      "type": "string"
    },
    "image": {
      "additionalProperties": false,
      "properties": {
        "pullPolicy": {
          "default": "IfNotPresent",
          "title": "pullPolicy",
          "type": "string"
        },
        "registry": {
          "default": "ghcr.io",
          "title": "registry",
          "type": "string"
        },
        "repository": {
          "default": "niklas-letz/cert-manager-webhook-solidserver",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [
        "registry",
        "repository",
        "tag",
        "pullPolicy"
      ],
      "title": "image",
      "type": "object"
    },
    "nameOverride": {
      "default": "",
      "title": "nameOverride",
      "type": "string"
    },
    "nodeSelector": {
      "additionalProperties": false,
      "required": [],
      "title": "nodeSelector",
      "type": "object"
    },
    "resources": {
      "additionalProperties": false,
      "required": [],
      "title": "resources",
      "type": "object"
    },
    "service": {
      "additionalProperties": false,
      "properties": {
        "port": {
          "default": 443,
          "title": "port",
          "type": "integer"
        },
        "type": {
          "default": "ClusterIP",
          "title": "type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "port"
      ],
      "title": "service",
      "type": "object"
    },
    "tolerations": {
      "items": {
        "required": []
      },
      "title": "tolerations",
      "type": "array"
    }
  },
  "required": [
    "groupName",
    "certManager",
    "image",
    "nameOverride",
    "fullnameOverride",
    "service",
    "resources",
    "nodeSelector",
    "tolerations",
    "affinity"
  ],
  "type": "object"
}